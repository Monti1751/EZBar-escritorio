<Window x:Class="EZBarEscritorio.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EZBar - Inicio de Sesión" 
        SizeToContent="Height" MinHeight="520" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border CornerRadius="25" Background="{StaticResource BackgroundCreamBrush}" BorderBrush="{StaticResource DarkBrownBrush}" BorderThickness="1.5">
        <Grid Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                <TextBlock Text="EZBAR" FontSize="42" FontWeight="ExtraBold" Foreground="{StaticResource DarkBrownBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Panel de Administración" FontSize="16" Opacity="0.8" HorizontalAlignment="Center" Foreground="{StaticResource DarkBrownBrush}" Margin="0,-5,0,0"/>
            </StackPanel>

            <!-- Cuerpo del Formulario -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="0,10">
                <TextBlock Text="USUARIO" FontSize="11" FontWeight="Bold" Margin="5,0,0,5" Foreground="{StaticResource DarkBrownBrush}" Opacity="0.6" />
                <Border Background="White" CornerRadius="12" Padding="12,8" Margin="0,0,0,20" BorderBrush="#DDD" BorderThickness="1">
                    <TextBox Text="{Binding Username}" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" FontSize="16" />
                </Border>

                <TextBlock Text="CONTRASEÑA" FontSize="11" FontWeight="Bold" Margin="5,0,0,5" Foreground="{StaticResource DarkBrownBrush}" Opacity="0.6" />
                <Border Background="White" CornerRadius="12" Padding="12,8" Margin="0,0,0,10" BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <!-- PasswordBox para modo oculto -->
                        <PasswordBox x:Name="PasswordInput" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" FontSize="16" 
                                     PasswordChanged="PasswordInput_PasswordChanged"
                                     Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        
                        <!-- TextBox para modo visible -->
                        <TextBox BorderThickness="0" Background="Transparent" 
                                 VerticalContentAlignment="Center" FontSize="16" 
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Checkbox Ver Contraseña -->
                <CheckBox IsChecked="{Binding IsPasswordVisible}" Content="Ver contraseña" 
                          FontSize="11" Foreground="{StaticResource DarkBrownBrush}" Opacity="0.7" 
                          Margin="5,0,0,15" VerticalContentAlignment="Center"
                          Checked="VerContrasena_Changed" Unchecked="VerContrasena_Changed" />

                <!-- Configuración Avanzada -->
                <CheckBox IsChecked="{Binding ShowApiUrl}" Content="Configuración avanzada" 
                          FontSize="10" Foreground="{StaticResource DarkBrownBrush}" Opacity="0.5" 
                          Margin="5,0,0,10" VerticalContentAlignment="Center" />

                <!-- Sección URL API (Oculta por defecto) -->
                <StackPanel Visibility="{Binding ShowApiUrl, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="URL API" FontSize="10" FontWeight="Bold" Margin="5,0,0,3" Foreground="{StaticResource DarkBrownBrush}" Opacity="0.4" />
                    <Border Background="#10000000" CornerRadius="8" Padding="10,4" Margin="0,0,0,5">
                        <TextBox Text="{Binding ApiUrl}" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" FontSize="11" Foreground="Gray" />
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Mensaje de Error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="#D32F2F" FontSize="12" 
                       FontWeight="SemiBold" Margin="0,5" HorizontalAlignment="Center" 
                       TextWrapping="Wrap" TextAlignment="Center" MinHeight="18" />

            <!-- Botones -->
            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                <Button Content="INICIAR SESIÓN" 
                        Command="{Binding LoginCommand}" 
                        Height="55" FontSize="18" FontWeight="Bold"
                        Background="{StaticResource DarkBrownBrush}" 
                        Foreground="White" Margin="0,0,0,10" />
                
                <Button Content="CERRAR APLICACIÓN" 
                        Click="Salir_Click"
                        Background="Transparent" 
                        Foreground="{StaticResource DarkBrownBrush}" 
                        BorderThickness="0"
                        FontSize="11" Opacity="0.5" />
            </StackPanel>

            <!-- Indicador de Carga -->
            <Border Grid.RowSpan="5" Background="#88FFFFFF" CornerRadius="25" 
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="6" Foreground="{StaticResource PrimaryGreenBrush}" Background="#20000000" BorderThickness="0" />
                    <TextBlock Text="Verificando credenciales..." Margin="0,15,0,0" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource DarkBrownBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
