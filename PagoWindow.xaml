<Window x:Class="EZBarEscritorio.PagoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmar Pago" Height="380" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FFF3E0">
    
    <!-- Definir un estilo base para colores cálidos/madera de la app -->
    <Window.Resources>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#4E342E" />
        <SolidColorBrush x:Key="PrimaryGreenBrush" Color="#2E7D32" />
        <SolidColorBrush x:Key="TextBrush" Color="#3E2723" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTotal" Grid.Row="0" Text="Total a Pagar: 0,00 €" 
                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource DarkBrownBrush}" 
                   HorizontalAlignment="Center" Margin="0,0,0,20" />

        <TextBlock Grid.Row="1" Text="Método de pago:" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5" />
        <ComboBox x:Name="cmbMetodoPago" Grid.Row="2" FontSize="16" Padding="5" Margin="0,0,0,20" SelectionChanged="cmbMetodoPago_SelectionChanged">
            <ComboBoxItem Content="Efectivo" IsSelected="True" />
            <ComboBoxItem Content="Tarjeta" />
            <ComboBoxItem Content="Transferencia" />
        </ComboBox>

        <StackPanel x:Name="panelEfectivo" Grid.Row="3" Visibility="Visible">
            <TextBlock Text="Monto recibido del cliente:" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5" />
            <TextBox x:Name="txtMontoRecibido" FontSize="18" Padding="5" Margin="0,0,0,15" TextChanged="txtMontoRecibido_TextChanged" />
            
            <TextBlock x:Name="txtCambio" Text="Cambio: 0,00 €" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryGreenBrush}" Margin="0,0,0,20" />
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnCancelar" Content="CANCELAR" Width="100" Padding="10" Margin="0,0,15,0" 
                    Background="#D32F2F" Foreground="White" FontWeight="Bold" Click="btnCancelar_Click" />
            <Button x:Name="btnConfirmar" Content="CONFIRMAR" Width="120" Padding="10" 
                    Background="{StaticResource PrimaryGreenBrush}" Foreground="White" FontWeight="Bold" Click="btnConfirmar_Click" IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
